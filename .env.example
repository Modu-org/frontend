# 백엔드 API 서버 주소 (Vite 프록시 target)
VITE_API_SERVER_URL=http://localhost:8080

# 프론트에서 사용하는 API base path (프록시 경유)
VITE_API_BASE_URL=/api

# 카카오 맵 JavaScript API 키 (https://developers.kakao.com 에서 발급)
VITE_KAKAO_MAP_KEY=your_kakao_map_key_here

# Mock 데이터 사용 여부 (true: 백엔드 없이 테스트 / false: 실제 API 연동)
VITE_USE_MOCK=false
